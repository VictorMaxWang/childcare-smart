{
  "name": "childcare-smart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "vivo:check-env": "node scripts/check-vivo-env-local.mjs",
    "vivo:check-env:partial": "node scripts/check-vivo-env-local.mjs --allow-partial",
    "vivo:configure-local": "powershell -ExecutionPolicy Bypass -File ./scripts/configure-vivo-env-local.ps1",
    "vivo:configure-vercel": "powershell -ExecutionPolicy Bypass -File ./scripts/configure-vivo-env-vercel.ps1",
    "typecheck": "tsc --noEmit --pretty false --incremental false",
    "test:parent-message-mapper": "node --import ./scripts/register-test-path-loader.mjs --test ./lib/agent/parent-message-reflexion.test.ts",
    "test:teacher-agent": "node --import ./scripts/register-test-path-loader.mjs --test ./app/api/ai/teacher-agent/route.test.ts ./lib/agent/teacher-agent.test.ts",
    "test:voice-assistant-parser": "node --import ./scripts/register-test-path-loader.mjs --test ./lib/voice-assistant/parser.test.ts",
    "test:demo-data-consistency": "node --import ./scripts/register-test-path-loader.mjs --test ./lib/demo-data/demo-data-consistency.test.ts && playwright test tests/product-completion/demo-data-consistency.spec.ts --config=playwright.product.config.ts",
    "ai:smoke": "node ./scripts/ai-suggestions-smoke.mjs",
    "ai:smoke:trend": "node ./scripts/ai-parent-trend-smoke.mjs",
    "ai:smoke:storybook": "node ./scripts/parent-storybook-smoke.mjs",
    "product:smoke": "playwright test tests/product-completion/api-scope.spec.ts tests/product-completion/full-user-journey.spec.ts --config=playwright.product.config.ts",
    "product:api": "playwright test tests/product-completion/api-scope.spec.ts tests/product-completion/crud-archive.spec.ts tests/product-completion/weekly-report.spec.ts tests/product-completion/feedback-attachments.spec.ts --config=playwright.product.config.ts",
    "product:ai": "node ./scripts/product-ai-smoke.mjs && playwright test tests/product-completion/vivo-provider.spec.ts tests/product-completion/ocr-asr-provider.spec.ts tests/product-completion/ai-routes-auth.spec.ts --config=playwright.product.config.ts",
    "release:check": "node ./scripts/release-check.mjs",
    "release:report": "node ./scripts/release-check.mjs",
    "release:report:local": "node ./scripts/release-check.mjs --report-path=./artifacts/release-report.local.json",
    "release:check:remote": "node ./scripts/release-check.mjs --require-remote",
    "release:report:remote": "node ./scripts/release-check.mjs --require-remote --report-path=./artifacts/release-report.remote.json",
    "release:gate:local": "npm run lint && npm run build && npm run release:check",
    "release:gate:remote": "npm run release:check:remote",
    "release:gate:remote:env": "node ./scripts/release-check.mjs --require-remote --release-env-file=.env.release --report-path=./artifacts/release-report.remote.json",
    "release:env:init": "node ./scripts/release-env-init.mjs",
    "release:env:check": "node ./scripts/release-env-check.mjs",
    "release:remote:reset": "node ./scripts/release-remote-reset.mjs",
    "release:go:remote": "npm run release:remote:reset && npm run release:env:init && npm run release:env:check && npm run release:gate:remote:env",
    "release:go:all": "npm run release:gate:local && npm run release:go:remote",
    "release:sql:pass": "node ./scripts/release-sql-check-set.mjs --overall-passed=true",
    "release:sql:fail": "node ./scripts/release-sql-check-set.mjs --overall-passed=false",
    "release:status": "node ./scripts/release-status.mjs",
    "release:ready": "node ./scripts/release-ready.mjs",
    "capture:ui": "playwright test tests/visual/capture-ui-screenshots.spec.ts --browser=chromium --reporter=line",
    "capture:visual-parity": "playwright test tests/visual/capture-visual-parity-key-pages.spec.ts --browser=chromium --reporter=line",
    "capture:visual-parity:round2": "playwright test tests/visual/capture-visual-parity-round2.spec.ts --browser=chromium --reporter=line",
    "capture:visual-parity:round3": "playwright test tests/visual/capture-visual-parity-round3.spec.ts --browser=chromium --reporter=line",
    "capture:visual-parity:round4": "playwright test tests/visual/capture-visual-parity-round4.spec.ts --browser=chromium --reporter=line",
    "capture:visual-parity:round5": "playwright test tests/visual/capture-visual-parity-round5.spec.ts --browser=chromium --reporter=line",
    "bugbash:smoke": "node ./scripts/bugbash-smoke-preflight.mjs && playwright test tests/bug-bash/real-user-smoke.spec.ts --config=playwright.bugbash.config.ts",
    "feature:smoke": "playwright test tests/feature-completion --config=playwright.feature.config.ts",
    "product:voice": "npm run test:voice-assistant-parser && playwright test tests/product-completion/e06-voice-assistant.spec.ts tests/product-completion/e07-director-voice-skills.spec.ts tests/product-completion/e08-teacher-voice-assistant.spec.ts tests/product-completion/e09-parent-voice-assistant.spec.ts tests/product-completion/voice-orb-core.spec.ts tests/product-completion/voice-director.spec.ts tests/product-completion/voice-teacher.spec.ts tests/product-completion/voice-parent.spec.ts --config=playwright.product.config.ts",
    "product:journey": "playwright test tests/product-completion/full-user-journey.spec.ts --config=playwright.product.config.ts",
    "feature:communication": "playwright test tests/feature-completion/communication-flow.spec.ts tests/feature-completion/parent-features.spec.ts --config=playwright.feature.config.ts",
    "feature:persistence": "playwright test tests/feature-completion/teacher-records-persistence.spec.ts tests/feature-completion/health-consultation.spec.ts tests/feature-completion/visual-only-safety.spec.ts --config=playwright.feature.config.ts",
    "package:gpt-image2": "node scripts/package-gpt-image2-input.mjs",
    "demo-media:ingest": "node scripts/ingest-gpt-image2-local-assets.mjs",
    "demo-media:test": "playwright test tests/product-completion/demo-media-ingest.spec.ts --config=playwright.product.config.ts --project=chromium --reporter=line",
    "growth-media:test": "playwright test tests/product-completion/growth-media-render.spec.ts --config=playwright.product.config.ts --project=chromium --reporter=line",
    "storybook:generate-xiaoyu-audio": "node scripts/generate-lin-xiaoyu-storybook-audio.mjs",
    "storybook:xiaoyu:test": "playwright test tests/product-completion/lin-xiaoyu-fixed-storybook.spec.ts --config=playwright.product.config.ts --project=chromium --reporter=line",
    "vivo:tts:test": "playwright test tests/product-completion/vivo-tts-provider.spec.ts --config=playwright.product.config.ts --project=chromium --reporter=line",
    "frontend:responsive": "playwright test tests/frontend-replica/responsive-states.spec.ts --config=playwright.product.config.ts --project=chromium --reporter=line",
    "frontend:states": "playwright test tests/frontend-replica/interaction-states.spec.ts --config=playwright.product.config.ts --project=chromium --reporter=line",
    "frontend:modals": "playwright test tests/frontend-replica/modals-drawers.spec.ts --config=playwright.product.config.ts --project=chromium --reporter=line",
    "frontend:mobile": "playwright test tests/frontend-replica/mobile-tablet.spec.ts --config=playwright.product.config.ts --project=chromium --reporter=line",
    "pixel:extract-assets": "node scripts/extract-pixel-assets.mjs",
    "pixel:capture": "node scripts/capture-pixel-pages.mjs",
    "pixel:compare": "node scripts/compare-pixel-parity.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.15.3",
    "next": "16.1.6",
    "pdfjs-dist": "^5.7.284",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.2.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
